{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.tesseraai/mcp-server",
  "title": "Tessera MCP Server",
  "description": "MCP server for Tessera's LLM cost-optimization layer: anchored spend, drift, recommendations.",
  "version": "0.1.2",
  "websiteUrl": "https://tesseraai.io/dev",
  "repository": {
    "url": "https://github.com/tessera-llm/mcp-server",
    "source": "github",
    "subfolder": "node"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@tessera-llm/mcp-server",
      "version": "0.1.2",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TESSERA_API_KEY",
          "description": "API key in tk_* format. Get one free at https://tesseraai.io/dev.",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "TESSERA_UPSTREAM_API_BASE_URL",
          "description": "Override only for staging or local-dev testing.",
          "isRequired": false,
          "default": "https://ledger.tesseraai.io"
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "status": "active",
      "license": "Apache-2.0",
      "categories": [
        "observability",
        "cost-optimization",
        "ai-infrastructure",
        "llm-tooling"
      ],
      "keywords": [
        "tessera",
        "mcp",
        "llm",
        "cost-optimization",
        "ai-cost",
        "llm-proxy",
        "openai",
        "anthropic",
        "claude",
        "savings",
        "audit"
      ],
      "transports_supported": ["stdio", "streamable-http"],
      "tools": [
        { "name": "tessera_list_workloads", "side_effect": "read" },
        { "name": "tessera_get_savings_report", "side_effect": "read" },
        { "name": "tessera_get_recommendation_queue", "side_effect": "read" },
        { "name": "tessera_get_ledger_entries", "side_effect": "read" },
        { "name": "tessera_get_quality_snapshot", "side_effect": "read" },
        { "name": "tessera_approve_recommendation", "side_effect": "write" }
      ],
      "client_compatibility": {
        "claude_desktop": "supported",
        "claude_code": "supported",
        "cursor": "supported",
        "cline": "supported",
        "continue": "supported",
        "goose": "supported_via_http",
        "zed": "supported_via_mcp_remote_bridge"
      },
      "security": {
        "auth_required": true,
        "auth_methods": ["api_key_env_var"],
        "auth_methods_planned": ["oauth_2.1"],
        "untrusted_content_labeling": "active",
        "scanned_by": ["tessera-static-scan v0.1"],
        "scanned_by_planned": ["snyk-agent-scan"]
      }
    }
  }
}
